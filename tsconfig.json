{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "lib": ["ES2023"],
    "types": ["node", "mocha"],
    "strict": false
  },
  "exclude": ["packages/", "gh-pages/"]
}
